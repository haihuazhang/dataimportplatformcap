        },
        {
          "ID": "3e8a5cb7-7bf3-4f73-9f87-9e5f7d8a3024",
          "ConfigUUID": "{{config_id}}",
          "StructureUUID": "{{schedule_structure_id}}",
          "FieldName": "DeliveryDate",
          "FieldDescription": "Delivery Date",
          "IsKeyField": false,
          "Sequence": 40,
          "IsForeignField": false,
          "FieldLength": 10,
          "FieldType": "DATE"
        },
        {
          "ID": "3e8a5cb7-7bf3-4f73-9f87-9e5f7d8a3025",
          "ConfigUUID": "{{config_id}}",
          "StructureUUID": "{{schedule_structure_id}}",
          "FieldName": "Quantity",
