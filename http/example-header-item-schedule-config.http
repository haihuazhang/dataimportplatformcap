    }
  ]
}

###
# Verify the created configuration with expanded structures and fields
GET {{service}}/BatchImportConfig(ID={{config_id}},IsActiveEntity=true)?$expand=to_Structures($orderby=SheetName;$expand=to_Fields($orderby=Sequence))
Authorization: {{basic_auth}}
Accept: application/json
